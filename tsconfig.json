{
  "compilerOptions": {
	"skipLibCheck": true,
	"esModuleInterop": true,
        "outDir": "./js/",
        "sourceMap": true,
        "module": "commonjs",
        "target": "es6",
        "jsx": "react",
	"strict": true
    },
  "include": ["src/**/*"],
  // Test files use *.test.ts(x); exclude stray Playwright-style *.spec.ts from the TS project.
  "exclude": [
    "node_modules",
    "**/*.spec.ts"
  ]
}

